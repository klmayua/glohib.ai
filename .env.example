# ================================================================================
# GLOHIB.AI - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# ================================================================================

# ------------------------------------------------------------------------------
# AI API KEYS (Moonshot/Kimi, OpenAI, etc.)
# ------------------------------------------------------------------------------
KIMI_API_KEY=sk-your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2-turbo-preview

OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# For self-hosted Llama models
LLAMA_MODEL_PATH=/path/to/llama-3-8b

# ------------------------------------------------------------------------------
# DATABASE - PostgreSQL
# ------------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=glohib
DATABASE_USER=glohib_admin
DATABASE_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://glohib_admin:your_secure_password_here@localhost:5432/glohib

# Redis for caching and queues
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# OBJECT STORAGE - MinIO (local) / S3 (production)
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=glohib-assets

# Production S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=glohib-production

# ------------------------------------------------------------------------------
# JWT & SESSION
# ------------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_EXPIRATION=24h
SESSION_SECRET=your_session_secret_minimum_32_characters

# ------------------------------------------------------------------------------
# API KEYS & RATE LIMITING
# ------------------------------------------------------------------------------
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60

# ------------------------------------------------------------------------------
# OBSERVABILITY
# ------------------------------------------------------------------------------
GRAFANA_CLOUD_URL=https://prometheus-prod-01-eu-west-0.grafana.net/api/prom/push
GRAFANA_CLOUD_USERNAME=your_grafana_username
GRAFANA_CLOUD_PASSWORD=your_grafana_password

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=glohib

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
ENABLE_VIDEO_ASSESSMENT=true
ENABLE_MENTORSHIP_MATCHING=true
ENABLE_ANALYTICS=true
DEBUG_MODE=false

# ------------------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------------------
NODE_ENV=development
PYTHONUNBUFFERED=1
