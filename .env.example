# =============================================================================
# GLOHIB.AI - ENVIRONMENT CONFIGURATION
# PWC 2030 Standard
# =============================================================================

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://glohib:GlohibAI_DB_Secure_2026!@localhost:5432/glohib_db?schema=public"

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# NEXTAUTH (Authentication)
# ------------------------------------------------------------------------------
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# OAUTH PROVIDERS
# ------------------------------------------------------------------------------
# LinkedIn OAuth (Primary)
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_CALLBACK_URL="http://localhost:3000/api/auth/callback/linkedin"

# Google OAuth (Secondary)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/callback/google"

# GitHub OAuth (Developer)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3000/api/auth/callback/github"

# ------------------------------------------------------------------------------
# EMAIL (SendGrid)
# ------------------------------------------------------------------------------
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@glohib.ai"

# ------------------------------------------------------------------------------
# STORAGE (Cloudflare R2)
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_BUCKET_NAME="glohib-assets"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# ------------------------------------------------------------------------------
# SEARCH (Meilisearch)
# ------------------------------------------------------------------------------
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ------------------------------------------------------------------------------
# AI SERVICES
# ------------------------------------------------------------------------------
OPENAI_API_KEY=""
KIMI_API_KEY=""

# ------------------------------------------------------------------------------
# IDENTITY SERVICE (Backend)
# ------------------------------------------------------------------------------
IDENTITY_SERVICE_URL="http://localhost:8080"

# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
