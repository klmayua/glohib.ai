# ================================================================================
# GLOHIB.AI - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# ================================================================================

# ------------------------------------------------------------------------------
# DATABASE - PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=glohib
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=glohib_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://glohib:CHANGE_ME_SECURE_PASSWORD@postgres:5432/glohib_db

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# OBJECT STORAGE - MinIO
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=glohib-assets
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ------------------------------------------------------------------------------
# JWT & AUTH
# ------------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_SECURE_RANDOM_STRING
JWT_EXPIRATION=24h
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MINIMUM_32_CHARACTERS

# ------------------------------------------------------------------------------
# AI API KEYS
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

KIMI_API_KEY=sk-your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2-turbo-preview

# ------------------------------------------------------------------------------
# SERVICE PORTS
# ------------------------------------------------------------------------------
IDENTITY_HTTP_PORT=8080
IDENTITY_GRPC_PORT=50051
STUDENT_HTTP_PORT=8082
INTERNSHIP_HTTP_PORT=8083
ASSESSMENT_HTTP_PORT=8084
ASSESSMENT_GRPC_PORT=50054
RECOMMENDATION_PORT=8007
SCORING_PORT=8008
VIDEO_PORT=4000

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60

# ------------------------------------------------------------------------------
# OAuth (Optional)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# OBSERVABILITY (Optional - Grafana Cloud)
# ------------------------------------------------------------------------------
GRAFANA_CLOUD_URL=
GRAFANA_CLOUD_USERNAME=
GRAFANA_CLOUD_PASSWORD=

# ------------------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------------------
NODE_ENV=development
PYTHONUNBUFFERED=1

