# Video Service Environment Variables

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_VIDEOS=glohib-videos
MINIO_USE_SSL=false

# Redis Configuration
REDIS_URL=redis://redis:6379

# PostgreSQL Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=glohib
DATABASE_PASSWORD=changeme
DATABASE_NAME=glohib_db

# NATS Configuration (optional)
NATS_URL=nats://nats:4222

# OpenAI Configuration (for transcription/grading)
OPENAI_API_KEY=

# TUS Upload Configuration
TUS_UPLOAD_DIR=/tmp/uploads

# Server Configuration
PORT=4000
LOG_LEVEL=info
