{
  "name": "@glohib/video-service",
  "version": "1.0.0",
  "description": "Glohib.ai Video Processing & WebRTC Signaling Service",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
