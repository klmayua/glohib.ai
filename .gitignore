# ================================================================================
# GLOHIB.AI - GITIGNORE
# Comprehensive ignore patterns for monorepo
# ================================================================================

# ------------------------------------------------------------------------------
# Environment & Secrets (CRITICAL - NEVER COMMIT)
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials/

# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/
vendor/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# Build Outputs
# ------------------------------------------------------------------------------
dist/
build/
out/
next-env.d.ts
.next/
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
docker-compose.override.yml
!docker-compose.override.yml.example
.docker/

# ------------------------------------------------------------------------------
# IDE & Editor
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
coverage/
.pytest_cache/
.coverage
htmlcov/

# ------------------------------------------------------------------------------
# Kubernetes & Terraform (selective)
# ------------------------------------------------------------------------------
# Keep manifests, ignore secrets
*-secret.yaml
terraform.tfstate
terraform.tfstate.backup
.terraform/

# ------------------------------------------------------------------------------
# Data & Uploads (local development)
# ------------------------------------------------------------------------------
data/local/
uploads/
temp/
tmp/

# ------------------------------------------------------------------------------
# Video Processing
# ------------------------------------------------------------------------------
video_cache/
*.mp4
*.webm
!*.md

# ------------------------------------------------------------------------------
# Database (local development)
# ------------------------------------------------------------------------------
*.db
*.sqlite
data/postgres/
