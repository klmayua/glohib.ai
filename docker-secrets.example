# Docker Secrets Configuration
# Use this file to manage secrets securely in Docker Swarm or with docker-compose
# 
# Usage:
# 1. Create actual secrets file: cp docker-secrets.example docker-secrets
# 2. Fill in actual secret values
# 3. Reference in docker-compose using secrets:
#    secrets:
#      - db_password
#      - jwt_secret
#
# secrets:
#   db_password:
#     file: ./docker-secrets/db_password.txt
#   jwt_secret:
#     file: ./docker-secrets/jwt_secret.txt

# Database Password
POSTGRES_PASSWORD=CHANGE_ME_SECURE_DATABASE_PASSWORD

# JWT Secret (minimum 32 characters)
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_SECURE_RANDOM_STRING

# Session Secret
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MINIMUM_32_CHARACTERS

# MinIO Credentials
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECURE_PASSWORD

# API Keys
OPENAI_API_KEY=sk-your_actual_openai_api_key_here
KIMI_API_KEY=sk-your_actual_kimi_api_key_here

# OAuth Secrets
GOOGLE_CLIENT_SECRET=your_google_oauth_secret_here

# Grafana Cloud (Optional)
GRAFANA_CLOUD_PASSWORD=your_grafana_cloud_password
