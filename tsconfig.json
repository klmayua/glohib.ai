{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@glohib/identity": ["services/identity-service/src"],
      "@glohib/student": ["services/student-service/src"],
      "@glohib/internship": ["services/internship-service/src"],
      "@glohib/assessment": ["services/assessment-service/src"],
      "@glohib/recommendation": ["services/recommendation-service/src"],
      "@glohib/scoring": ["services/scoring-service/src"],
      "@glohib/video": ["services/video-service/src"],
      "@frontend/web": ["frontend/web/src"],
      "@frontend/web/*": ["frontend/web/src/*"]
    }
  },
  "include": [],
  "exclude": ["node_modules", "dist", "build", "**/vendor/**"]
}
